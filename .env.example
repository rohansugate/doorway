# Supabase — user accounts, roles, and passwords (required for auth)
# Passwords are stored hashed in Supabase Auth (auth.users), not in public.profiles.
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Recommended for production signup — lets the server confirm accounts immediately
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — required for two-phone demo sync on Vercel
# Add via: Vercel Dashboard → Storage → Upstash Redis → Connect to project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional shared demo room (defaults to doorway-hackathon)
# DOORWAY_DEMO_ROOM=doorway-hackathon
